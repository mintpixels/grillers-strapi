{
  "collectionName": "components_curated_curation_slots",
  "info": {
    "displayName": "Curation Slot",
    "description": "A rule-based slot for picker/agentic fulfillment when the exact SKU should remain flexible."
  },
  "options": {},
  "attributes": {
    "Label": {
      "type": "string",
      "required": true
    },
    "CategoryRule": {
      "type": "text",
      "required": true
    },
    "MinWeightLb": {
      "type": "decimal",
      "required": false
    },
    "MaxWeightLb": {
      "type": "decimal",
      "required": false
    },
    "MinPricePerLb": {
      "type": "decimal",
      "required": false
    },
    "MaxPricePerLb": {
      "type": "decimal",
      "required": false
    },
    "Required": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "ExampleProducts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product"
    },
    "Notes": {
      "type": "text",
      "required": false
    },
    "SortOrder": {
      "type": "integer",
      "required": false
    }
  }
}
