{
  "kind": "collectionType",
  "collectionName": "legal_pages",
  "info": {
    "singularName": "legal-page",
    "pluralName": "legal-pages",
    "displayName": "Legal Page",
    "description": "Privacy Policy, Terms of Sale, Terms of Use, About, Shipping, etc. — one entry per slug. Renders at /us/legal/[slug]."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Slug": {
      "type": "uid",
      "targetField": "Title",
      "required": true
    },
    "Title": {
      "type": "string",
      "required": true
    },
    "Hero": {
      "type": "component",
      "repeatable": false,
      "component": "info.hero"
    },
    "Body": {
      "type": "dynamiczone",
      "components": [
        "info.section",
        "info.feature-grid",
        "info.image-block",
        "shared.rich-text"
      ]
    },
    "Content": {
      "type": "blocks"
    },
    "SEO": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "SocialMeta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.social-meta"
    }
  }
}
