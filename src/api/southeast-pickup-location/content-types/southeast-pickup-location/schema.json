{
  "kind": "collectionType",
  "collectionName": "southeast_pickup_locations",
  "info": {
    "singularName": "southeast-pickup-location",
    "pluralName": "southeast-pickup-locations",
    "displayName": "SoutheastPickupLocation",
    "description": "Cities available for Southeast pickup with scheduled dates"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "City": {
      "type": "string",
      "required": true
    },
    "State": {
      "type": "enumeration",
      "enum": ["AL", "AR", "AZ", "CA", "CO", "CT", "DE", "FL", "GA", "IA", "ID", "IL", "IN", "KS", "KY", "LA", "MA", "MD", "ME", "MI", "MN", "MO", "MS", "MT", "NC", "ND", "NE", "NH", "NJ", "NM", "NV", "NY", "OH", "OK", "OR", "PA", "RI", "SC", "SD", "TN", "TX", "UT", "VA", "VT", "WA", "WI", "WV", "WY"],
      "required": true
    },
    "Address": {
      "type": "string"
    },
    "ZipCode": {
      "type": "string"
    },
    "IsActive": {
      "type": "boolean",
      "default": true
    },
    "AvailableDates": {
      "type": "component",
      "component": "checkout.plant-pickup-date",
      "repeatable": true
    },
    "CutoffDays": {
      "type": "integer",
      "default": 3
    },
    "Description": {
      "type": "text"
    }
  }
}
