{
  "kind": "singleType",
  "collectionName": "checkouts",
  "info": {
    "singularName": "checkout",
    "pluralName": "checkouts",
    "displayName": "Checkout"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "ShippingBlackoutDaysOfWeek": {
      "type": "customField",
      "customField": "plugin::multi-select.multi-select",
      "default": "[]",
      "options": [
        "Sunday",
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday"
      ]
    },
    "ShippingBlackoutDates": {
      "type": "component",
      "component": "checkout.shipping-blackout-dates",
      "repeatable": true
    },
    "DeliveryLeadTime": {
      "type": "integer"
    },
    "UPSSameDayCutoffTime": {
      "type": "string"
    },
    "LocalPickupSameDayText": {
      "type": "string"
    },
    "PlantPickupAvailableDays": {
      "type": "json",
      "default": ["Tuesday", "Wednesday"]
    },
    "PlantPickupAdditionalDates": {
      "type": "component",
      "component": "checkout.plant-pickup-date",
      "repeatable": true
    },
    "PlantPickupBlackoutDates": {
      "type": "component",
      "component": "checkout.plant-pickup-date",
      "repeatable": true
    },
    "PlantPickupPostOrderNote": {
      "type": "text",
      "default": "We will call you when your order is ready on the day of pickup."
    },
    "PlantPickupCutoffHours": {
      "type": "integer",
      "default": 0
    },
    "SEO": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
