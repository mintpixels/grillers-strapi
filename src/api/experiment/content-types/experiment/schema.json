{
  "kind": "collectionType",
  "collectionName": "experiments",
  "info": {
    "singularName": "experiment",
    "pluralName": "experiments",
    "displayName": "Experiment",
    "description": "Storefront experiment definitions managed with Statsig assignment and Jitsu measurement"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true
    },
    "Key": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "Status": {
      "type": "enumeration",
      "enum": ["draft", "active", "paused", "archived"],
      "default": "draft",
      "required": true
    },
    "Surface": {
      "type": "enumeration",
      "enum": [
        "homepage",
        "pdp",
        "navigation",
        "plp",
        "search",
        "recipes",
        "learn",
        "collections",
        "cart",
        "pdp_recommendations",
        "newsletter",
        "seo_geo",
        "reviews"
      ],
      "required": true
    },
    "Impact": {
      "type": "enumeration",
      "enum": ["revenue", "non_revenue"],
      "default": "non_revenue",
      "required": true
    },
    "StatsigExperimentKey": {
      "type": "string"
    },
    "DefaultVariantKey": {
      "type": "string",
      "default": "control",
      "required": true
    },
    "PrimaryMetric": {
      "type": "enumeration",
      "enum": [
        "add_to_cart",
        "checkout_started",
        "order_completed",
        "revenue",
        "engagement"
      ],
      "default": "order_completed"
    },
    "Hypothesis": {
      "type": "text"
    },
    "GuardrailNotes": {
      "type": "text"
    },
    "RevenueGateRequired": {
      "type": "boolean",
      "default": true,
      "required": true
    }
  }
}
